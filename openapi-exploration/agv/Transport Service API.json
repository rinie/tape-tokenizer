{
  "openapi": "3.0.1",
  "info": {
    "title": "Transport Service",
    "description": "T-ONE - Transport Service Integration Specification",
    "version": "1.0",
    "contact": {
      "name": "TMHLS"
    }
  },
  "paths": {
    "/api/v1/transports/{id}/currentinstruction": {
      "get": {
        "tags": [
          "CurrentInstruction"
        ],
        "summary": "Get the current instruction of a transport",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the transport.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/Traceparent"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Instruction"
                },
                "examples": {
                  "Instruction to pick up a load": {
                    "value": {
                      "locationName": "Location A",
                      "action": "PickUp",
                      "loads": [
                        [
                          "507f1f77bcf86cd799439011"
                        ]
                      ],
                      "state": {
                        "code": "Pending"
                      }
                    }
                  }
                }
              }
            }
          },
          "204": {
            "description": "No Content : No instruction to execute for the transport."
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/Not-Found"
          },
          "410": {
            "description": "Gone : The transport is already finished and no instructions are left to execute.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "examples": {
                  "Transport already finished": {
                    "value": {
                      "type": "https://tools.ietf.org/html/rfc7231#section-6.5.9",
                      "title": "Gone",
                      "status": 410,
                      "traceId": "00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-01"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/Internal-Server-Error"
          },
          "503": {
            "$ref": "#/components/responses/Service-Unavailable"
          }
        },
        "operationId": "get-api-v1-transports-id-currentinstruction",
        "description": "Retrieves information about the current instruction of the transport based on the ID"
      },
      "parameters": [
        {
          "schema": {
            "type": "string"
          },
          "name": "id",
          "in": "path",
          "required": true,
          "description": "The ID of the transport"
        }
      ]
    },
    "/api/v1/transports": {
      "get": {
        "tags": [
          "Transports"
        ],
        "summary": "Get transports",
        "parameters": [
          {
            "name": "Ids",
            "in": "query",
            "description": "Only include transports with IDs specified in this array.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true,
              "minItems": 0
            }
          },
          {
            "name": "ExternalTransportIds",
            "in": "query",
            "description": "Only include transports with external identifiers specified in this array.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true,
              "minItems": 0
            }
          },
          {
            "name": "MinPriority",
            "in": "query",
            "description": "Only include transports with a priority equal or greater than the specified value.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0,
              "maximum": 99
            }
          },
          {
            "name": "MaxPriority",
            "in": "query",
            "description": "Only include transports with a priority equal or less than the specified value.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0,
              "maximum": 99
            }
          },
          {
            "name": "Vehicles",
            "in": "query",
            "description": "Only include transports associated with a vehicle specified in this array.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 0,
              "uniqueItems": true
            }
          },
          {
            "name": "States",
            "in": "query",
            "description": "Only include transports with a state code specified in this array.",
            "schema": {
              "type": "array",
              "items": {
                "enum": [
                  "Pending",
                  "Ongoing",
                  "Waiting",
                  "Completed",
                  "Aborted",
                  "Rejected",
                  "Error"
                ],
                "type": "string",
                "description": "Describes the possible states of a transport."
              },
              "minItems": 0,
              "uniqueItems": true
            }
          },
          {
            "name": "AfterCreatedDateTime",
            "in": "query",
            "description": "Only include transports that have a Created Date Time equal or greater than the specified value.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "BeforeCreatedDateTime",
            "in": "query",
            "description": "Only include transports that have a Created Date Time equal or less than the specified value.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "AfterFinishedDateTime",
            "in": "query",
            "description": "Only include transports that have a Finished Date Time equal or greater than the specified value.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "BeforeFinishedDateTime",
            "in": "query",
            "description": "Only include transports that have a Finished Date time equal or less than the specified value.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "$ref": "#/components/parameters/Traceparent"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Transport"
                  }
                },
                "examples": {
                  "Array of transports": {
                    "value": [
                      {
                        "id": "507f1f77bcf86cd799439011",
                        "externalTransportId": "externalIdentifier",
                        "metadata": null,
                        "priority": 3,
                        "dueTime": "2020-10-27T10:50:00.000Z",
                        "currentInstruction": 0,
                        "instructions": [
                          {
                            "locationName": "C-1",
                            "action": "None",
                            "loads": [
                              [
                                "407f1f77bcf86cd799439012"
                              ]
                            ],
                            "state": {
                              "code": "Pending",
                              "reason": null,
                              "data": null
                            }
                          },
                          {
                            "locationName": "A",
                            "action": "PickUp",
                            "loads": [
                              [
                                "407f1f77bcf86cd799439012"
                              ]
                            ],
                            "state": {
                              "code": "Pending",
                              "reason": null,
                              "data": null
                            }
                          },
                          {
                            "locationName": "B",
                            "action": "DropOff",
                            "loads": [
                              [
                                "407f1f77bcf86cd799439012"
                              ]
                            ],
                            "state": {
                              "code": "Pending",
                              "reason": null,
                              "data": null
                            }
                          }
                        ],
                        "vehicles": [
                          {
                            "name": "AGV 13"
                          }
                        ],
                        "abortRequested": false,
                        "state": {
                          "code": "Ongoing",
                          "reason": null,
                          "data": null
                        },
                        "createdDateTime": "2020-10-27T10:40:00.000Z",
                        "startedDateTime": "2020-10-27T10:43:00.000Z",
                        "finishedDateTime": null,
                        "lastModifiedDateTime": "2020-10-27T10:43:00.000Z"
                      }
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/Internal-Server-Error"
          },
          "503": {
            "$ref": "#/components/responses/Service-Unavailable"
          }
        },
        "operationId": "get-api-v1-transports",
        "description": "Returns all the existing transports in the system matching the query."
      },
      "post": {
        "tags": [
          "Transports"
        ],
        "summary": "Creates a new transport.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Request-Id"
          },
          {
            "$ref": "#/components/parameters/Traceparent"
          }
        ],
        "requestBody": {
          "description": "The transport to create",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Transport"
              },
              "examples": {
                "Create a transport to move a load from A to B": {
                  "value": {
                    "externalTransportId": "external-identifier",
                    "priority": 1,
                    "dueTime": "2020-10-27T15:00:00.000Z",
                    "instructions": [
                      {
                        "locationName": "A",
                        "action": "PickUp",
                        "loads": [
                          [
                            "407f1f77bcf86cd799439012"
                          ]
                        ]
                      },
                      {
                        "locationName": "B",
                        "action": "DropOff",
                        "loads": [
                          [
                            "407f1f77bcf86cd799439012"
                          ]
                        ]
                      }
                    ]
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transport"
                },
                "examples": {
                  "The newly created transport": {
                    "value": {
                      "id": "507f1f77bcf86cd799439011",
                      "externalTransportId": "external-identifier",
                      "metadata": null,
                      "priority": 1,
                      "dueTime": "2020-10-27T15:00:00.000Z",
                      "currentInstruction": 0,
                      "instructions": [
                        {
                          "locationName": "A",
                          "action": "PickUp",
                          "loads": [
                            [
                              "407f1f77bcf86cd799439012"
                            ]
                          ],
                          "state": {
                            "code": "Pending",
                            "reason": null,
                            "data": null
                          }
                        },
                        {
                          "locationName": "B",
                          "action": "DropOff",
                          "loads": [
                            [
                              "407f1f77bcf86cd799439012"
                            ]
                          ],
                          "state": {
                            "code": "Pending",
                            "reason": null,
                            "data": null
                          }
                        }
                      ],
                      "vehicles": [],
                      "abortRequested": false,
                      "state": {
                        "code": "Pending"
                      },
                      "createdDateTime": "2020-10-27T10:40:00.000Z",
                      "lastModifiedDateTime": "2020-10-27T10:40:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationProblemDetails"
                },
                "examples": {
                  "Forgot to specify a load ID": {
                    "value": {
                      "errors": {
                        "Instruction[0].Loads[0]": [
                          "The field Loads[0] must be an array type with a minimum and maximum length of '1'."
                        ]
                      },
                      "type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                      "title": "One or more validation errors occurred.",
                      "status": 400,
                      "traceId": "00-f8b1ce1398dc9f4dab765371a4272440-a84980c10a99f545-00"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/Internal-Server-Error"
          },
          "503": {
            "$ref": "#/components/responses/Service-Unavailable"
          }
        },
        "operationId": "post-api-v1-transports",
        "description": "Creates a new transport to move a load"
      }
    },
