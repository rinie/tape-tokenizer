  "components": {
    "schemas": {
      "Instruction": {
        "type": "object",
        "additionalProperties": false,
        "description": "Describes a part of a transport.",
        "properties": {
          "locationName": {
            "type": "string",
            "description": ""
          },
          "action": {
            "enum": [
              "None",
              "PickUp",
              "DropOff"
            ],
            "type": "string",
            "description": "",
            "default": "None"
          },
          "loads": {
            "maxItems": 1,
            "minItems": 1,
            "type": "array",
            "description": "",
            "items": {
              "type": "array",
              "items": {
                "type": "string",
                "example": "507f1f77bcf86cd799439011"
              }
            }
          },
          "state": {
            "type": "object",
            "description": "The state of the instruction",
            "additionalProperties": false,
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "Pending",
                  "Completed",
                  "Failed"
                ],
                "default": "Pending",
                "readOnly": true
              },
              "reason": {
                "type": "string",
                "nullable": true,
                "readOnly": true
              },
              "data": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "nullable": true,
                "readOnly": true
              }
            },
            "readOnly": true
          }
        },
        "required": [
          "locationName",
          "loads"
        ]
      },
      "PatchOperation": {
        "title": "JsonPatchOperation",
        "required": [
          "op",
          "path"
        ],
        "type": "object",
        "allOf": [
          {
            "properties": {
              "path": {
                "type": "string",
                "description": "A JSON Pointer path."
              }
