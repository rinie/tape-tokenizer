      "patch": {
        "tags": [
          "Transports"
        ],
        "summary": "Update transport information",
        "description": "Updates the information about an existing transport.\n\n**Supported Parameters**\n- Priority\n- Due Time\n- Instructions\n  - An instruction can only be inserted/added after the current instruction.\n  - An instruction can only be modified if it has not already been executed or is being executed.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the transport to update.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/Request-Id"
          },
          {
            "$ref": "#/components/parameters/Traceparent"
          }
        ],
        "requestBody": {
          "description": "The document describing the changes to apply.",
          "content": {
            "application/json-patch+json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PatchOperation"
                }
              },
              "examples": {
                "Change priority and append new instruction": {
                  "value": [
                    {
                      "op": "replace",
                      "path": "/priority",
                      "value": 20
                    },
                    {
                      "op": "add",
                      "path": "/instructions/-",
                      "value": {
                        "locationName": "location-name",
                        "action": "None",
                        "loads": [
                          [
                            "407f1f77bcf86cd799439012"
                          ]
                        ]
                      }
                    }
                  ]
                }
              }
            }
          },
          "required": true
        },
        "responses": {
