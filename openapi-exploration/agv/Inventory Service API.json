                  "$ref": "#/components/schemas/Load"
                },
                "examples": {
                  "The removed load": {
                    "value": {
                      "id": "fa6b8101-4e12-4ec7-abe3-5fc4ca1c584b",
                      "data": {
                        "article": "Cola",
                        "productionDate": "2020-11-26"
                      },
                      "dimensions": {
                        "width": 800,
                        "height": 144,
                        "length": null
                      },
                      "weight": 120,
                      "loadCarrierType": "euro",
                      "stackability": "NonStackable",
                      "location": {
                        "name": "Location A",
                        "position": 0,
                        "positionQualifier": "Calculated"
                      },
                      "state": "Stored",
                      "createdDateTime": "2019-08-24T14:15:22Z",
                      "lastModifiedDateTime": "2019-08-24T14:15:22Z"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/Not-Found"
          },
          "409": {
            "description": "Conflict : Load is not in _Stored_ state",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "examples": {
                  "Conflict": {
                    "value": {
                      "type": "https://tools.ietf.org/html/rfc7231#section-6.5.8",
                      "title": "Conflict",
                      "status": 409,
                      "traceId": "00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-01"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/Internal-Server-Error"
          },
          "503": {
            "$ref": "#/components/responses/Service-Unavailable"
          }
        },
        "operationId": "delete-api-v1-loads-id",
        "tags": [
          "Loads"
        ],
        "description": "Removes the information about a single load based on the ID"
      },
      "parameters": [
        {
          "schema": {
            "type": "string"
          },
          "name": "id",
          "in": "path",
          "required": true,
          "description": "The ID of the load"
        }
      ]
    },
    "/api/v1/loads": {
      "get": {
        "summary": "Get loads",
        "parameters": [
          {
            "name": "Ids",
            "in": "query",
            "description": "Filter on loads with these ids",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Filter on loads with these ids",
              "uniqueItems": true,
              "minItems": 0
            }
          },
          {
            "name": "LocationNames",
            "in": "query",
            "description": "Filter on loads with these location names",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Filter on loads with these location names",
              "uniqueItems": true,
              "minItems": 0
            }
          },
          {
            "name": "Filters",
            "in": "query",
            "description": "Filter on loads with these data filters",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Filter on loads with these data filters",
              "uniqueItems": true,
              "minItems": 0
            }
          },
          {
            "$ref": "#/components/parameters/Traceparent"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Load"
                  }
                },
                "examples": {
                  "An array of loads": {
                    "value": [
                      {
                        "id": "fa6b8101-4e12-4ec7-abe3-5fc4ca1c584b",
                        "data": {
                          "article": "Cola",
                          "productionDate": "2020-11-26"
                        },
                        "dimensions": {
                          "width": 800,
                          "height": 144,
                          "length": null
                        },
                        "weight": 120,
                        "loadCarrierType": "euro",
                        "stackability": "NonStackable",
                        "location": {
                          "name": "Location A",
                          "position": 0,
                          "positionQualifier": "Calculated"
                        },
                        "state": "Stored",
                        "createdDateTime": "2019-08-24T14:15:22Z",
                        "lastModifiedDateTime": "2019-08-24T14:15:22Z"
                      }
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/Internal-Server-Error"
          },
          "503": {
            "$ref": "#/components/responses/Service-Unavailable"
          }
        },
        "operationId": "get-api-v1-loads",
        "tags": [
          "Loads"
        ],
        "description": "Returns all the existing loads in the system matching the query."
      },
      "post": {
        "summary": "Add new load",
        "parameters": [
          {
            "$ref": "#/components/parameters/Request-Id"
          },
          {
            "$ref": "#/components/parameters/Traceparent"
          }
        ],
        "requestBody": {
          "description": "The load to add",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Load"
              },
              "examples": {
                "Adds load of cola to the system": {
                  "value": {
                    "data": {
                      "article": "Cola",
                      "productionDate": "2020-11-26"
                    },
                    "weight": 5.5,
                    "loadCarrierType": "EURO",
                    "location": {
                      "name": "Location A"
                    }
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Load"
                },
                "examples": {
                  "The newly added load": {
                    "value": {
                      "id": "fa6b8101-4e12-4ec7-abe3-5fc4ca1c584b",
                      "data": {
                        "article": "Cola",
                        "productionDate": "2020-11-26"
                      },
                      "dimensions": {
                        "width": null,
                        "height": null,
                        "length": null
                      },
                      "weight": 5.5,
                      "loadCarrierType": "EURO",
                      "stackability": "NonStackable",
                      "location": {
                        "name": "Location A",
                        "position": 0,
                        "positionQualifier": "Calculated"
                      },
                      "state": "Stored",
                      "createdDateTime": "2019-08-24T14:15:22Z",
                      "lastModifiedDateTime": "2019-08-24T14:15:22Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationProblemDetails"
                },
                "examples": {
                  "The location object is not specified": {
                    "value": {
                      "errors": {
                        "Location": [
                          "The Location field is required."
                        ]
                      },
                      "type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                      "title": "One or more validation errors occurred.",
                      "status": 400,
                      "traceId": "00-5b46f2db83480248bd7ef2c578b2efd7-ab8595268a0bb44d-00"
                    }
                  },
                  "The location name is not specified": {
                    "value": {
                      "errors": {
                        "Location.Name": [
                          "The Name field is required."
                        ]
                      },
                      "type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                      "title": "One or more validation errors occurred.",
                      "status": 400,
                      "traceId": "00-51d7b8350505044183665270b84c48fb-b1e93ed63c8d464b-00"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "description": "Conflict : There is no more space at the location for the given load. A load must be removed from the unload side of the location before a new one can be added",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "examples": {
                  "Conflict": {
                    "value": {
                      "type": "https://tools.ietf.org/html/rfc7231#section-6.5.8",
                      "title": "Conflict",
                      "status": 409,
                      "traceId": "00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-01"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/Internal-Server-Error"
          },
          "503": {
            "$ref": "#/components/responses/Service-Unavailable"
          }
        },
        "operationId": "post-api-v1-loads",
        "tags": [
          "Loads"
        ],
        "description": "Adds a new load to the system"
