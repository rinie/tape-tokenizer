          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "nullable": true,
            "readOnly": true
          }
        },
        "additionalProperties": {}
      },
      "Load": {
        "type": "object",
        "additionalProperties": false,
        "description": "Represents a single load in the system",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "fa6b8101-4e12-4ec7-abe3-5fc4ca1c584b",
            "readOnly": true
          },
          "data": {
            "type": "object",
            "nullable": true
          },
          "dimensions": {
            "type": "object",
            "properties": {
              "width": {
                "type": "integer",
                "nullable": true
              },
              "height": {
                "type": "integer",
                "nullable": true
              },
              "length": {
                "type": "integer",
                "nullable": true
              }
            }
          },
          "weight": {
            "type": "number",
            "nullable": true
          },
          "loadCarrierType": {
            "type": "string"
          },
          "stackability": {
            "type": "string",
            "enum": [
              "NonStackable",
              "FullyStackable",
              "FloorStackable",
              "TopStackable"
            ],
            "default": "NonStackable"
          },
          "location": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "position": {
                "type": "integer",
                "readOnly": true
              },
              "positionQualifier": {
                "type": "string",
                "enum": [
                  "Calculated",
                  "Actual"
                ],
                "readOnly": true
              }
            }
          },
          "state": {
            "type": "string",
            "enum": [
              "Stored",
              "Reserved",
              "In Transit",
              "Lost"
            ],
            "default": "Stored",
            "readOnly": true
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "lastModifiedDateTime": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        },
        "required": [
          "loadCarrierType",
          "location"
        ]
      },
      "PatchOperation": {
        "title": "PatchOperation",
        "required": [
          "op",
          "path"
        ],
        "type": "object",
        "allOf": [
          {
            "properties": {
              "path": {
                "type": "string",
                "description": "A JSON Pointer path."
              }
            }
          }
        ],
        "oneOf": [
          {
            "required": [
              "op",
              "value"
            ],
            "properties": {
              "op": {
                "enum": [
                  "add",
                  "replace",
                  "test"
                ],
                "type": "string",
                "description": "The operation to perform."
              },
              "value": {
                "description": "The value to add, replace of test."
              }
            }
          },
          {
            "required": [
              "op"
            ],
            "properties": {
              "op": {
                "enum": [
                  "remove"
                ],
                "type": "string",
                "description": "The operation to perform."
              }
            }
          },
          {
            "required": [
              "op",
              "from"
            ],
            "properties": {
              "op": {
                "enum": [
                  "move",
                  "copy"
                ],
                "type": "string",
                "description": "The operation to perform"
              },
              "from": {
                "type": "string",
                "description": "A JSON Pointer path pointing to the location to move/copy from."
              }
            }
          }
        ],
        "externalDocs": {
          "description": "JSON Patch Documentation",
          "url": "https://jsonpatch.com"
        },
        "x-examples": {},
        "description": ""
      }
    },
